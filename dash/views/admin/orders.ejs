<%- include('../partials/admin-header') %>

<div class="card fade-in">
    <div class="card-header">
        <h3 class="card-title">All Orders</h3>
        <div class="header-actions">
            <select class="form-control" onchange="window.location.href='/admin/orders?status=' + this.value" style="width: auto;">
                <option value="all" <%= currentStatus === 'all' ? 'selected' : '' %>>All Status</option>
                <option value="pending" <%= currentStatus === 'pending' ? 'selected' : '' %>>Pending</option>
                <option value="paid" <%= currentStatus === 'paid' ? 'selected' : '' %>>Paid</option>
                <option value="active" <%= currentStatus === 'active' ? 'selected' : '' %>>Active</option>
            </select>
        </div>
    </div>
    <div class="table-container">
        <table class="table">
            <thead>
                <tr>
                    <th>Order ID</th>
                    <th>Product</th>
                    <th>User</th>
                    <th>Billing Cycle</th>
                    <th>Amount</th>
                    <th>Status</th>
                    <th>Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% orders.forEach(order => { %>
                <tr>
                    <td>#<%= order.id.slice(0, 8) %></td>
                    <td><%= order.productName %></td>
                    <td><%= order.userId.slice(0, 8) %></td>
                    <td><%= order.billingCycle %></td>
                    <td>₹<%= order.price %></td>
                    <td>
                        <span class="badge badge-<%= 
                            order.status === 'active' ? 'success' : 
                            order.status === 'pending' ? 'warning' : 
                            order.status === 'paid' ? 'info' : 'danger' 
                        %>">
                            <%= order.status %>
                        </span>
                    </td>
                    <td><%= moment(order.createdAt).format('MMM D, YYYY') %></td>
                    <td>
                        <a href="/admin/orders/<%= order.id %>" class="btn btn-outline btn-sm">
                            <i class="fas fa-eye"></i>
                        </a>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>

<!-- Pagination -->
<% if (pagination.totalPages > 1) { %>
<div class="pagination">
    <% if (pagination.hasPrev) { %>
        <a href="?page=<%= pagination.page - 1 %>" class="page-link">Previous</a>
    <% } %>
    
    <% for (let i = 1; i <= pagination.totalPages; i++) { %>
        <a href="?page=<%= i %>" class="page-link <%= i === pagination.page ? 'active' : '' %>">
            <%= i %>
        </a>
    <% } %>
    
    <% if (pagination.hasNext) { %>
        <a href="?page=<%= pagination.page + 1 %>" class="page-link">Next</a>
    <% } %>
</div>
<% } %>

<%- include('../partials/admin-footer') %>