<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>500 - Server Error</title>
  <link rel="stylesheet" href="/css/style.css" />
  <style>
    .error-container { text-align: center; margin-top: 80px; font-family: Arial, sans-serif; }
    .error-code { font-size: 100px; font-weight: bold; color: #c0392b; }
    .error-message { font-size: 22px; color: #2c3e50; }
    .error-details { background: #f8d7da; color: #721c24; padding: 15px; margin: 20px auto; max-width: 800px; border-radius: 5px; font-family: monospace; text-align: left; }
    .back-link { margin-top: 20px; display: inline-block; padding: 10px 20px; background: #27ae60; color: white; text-decoration: none; border-radius: 5px; }
  </style>
</head>
<body>
  <%- include('partials/header') %>
  <div class="error-container">
    <div class="error-code">500</div>
    <div class="error-message">Internal Server Error</div>
    <p>Something went wrong on our end. We're working to fix it.</p>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="error-details">
        <strong>Error:</strong> <%= error.message || error %><br>
        <% if (error.stack) { %>
          <pre style="white-space: pre-wrap; font-size: 12px; margin-top: 10px;"><%= error.stack %></pre>
        <% } %>
      </div>
    <% } %>

    <a href="javascript:history.back()" class="back-link">Go Back</a>
    <a href="/" class="back-link" style="margin-left: 10px;">Home</a>
  </div>
  <%- include('partials/footer') %>
</body>
</html>