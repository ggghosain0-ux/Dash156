<%- include('../partials/admin-header') %>

<div class="card fade-in">
    <div class="card-header">
        <h3 class="card-title">Order #<%= order.id %></h3>
        <a href="/admin/orders" class="btn btn-outline">Back to Orders</a>
    </div>
    <div style="padding: 1.5rem;">
        
        <!-- Order Status Update -->
        <form action="/admin/orders/<%= order.id %>/status" method="POST" class="form-group" style="margin-bottom: 2rem;">
            <div style="display: flex; gap: 1rem; align-items: end;">
                <div>
                    <label class="form-label">Update Status</label>
                    <select name="status" class="form-control" style="width: auto;">
                        <option value="pending" <%= order.status === 'pending' ? 'selected' : '' %>>Pending</option>
                        <option value="paid" <%= order.status === 'paid' ? 'selected' : '' %>>Paid</option>
                        <option value="active" <%= order.status === 'active' ? 'selected' : '' %>>Active</option>
                        <option value="suspended" <%= order.status === 'suspended' ? 'selected' : '' %>>Suspended</option>
                        <option value="cancelled" <%= order.status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
                    </select>
                </div>
                <button type="submit" class="btn btn-primary">Update Status</button>
            </div>
        </form>

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem;">
            
            <!-- Order Details -->
            <div>
                <h4 style="margin-bottom: 1rem; color: var(--light);">Order Information</h4>
                <div style="background: var(--dark); padding: 1.5rem; border-radius: 8px;">
                    <div style="display: grid; gap: 0.75rem;">
                        <div style="display: flex; justify-content: between;">
                            <span style="color: var(--gray-light);">Order ID:</span>
                            <span><%= order.id %></span>
                        </div>
                        <div style="display: flex; justify-content: between;">
                            <span style="color: var(--gray-light);">Status:</span>
                            <span class="badge badge-<%= 
                                order.status === 'active' ? 'success' : 
                                order.status === 'pending' ? 'warning' : 
                                order.status === 'paid' ? 'info' : 'danger' 
                            %>">
                                <%= order.status %>
                            </span>
                        </div>
                        <div style="display: flex; justify-content: between;">
                            <span style="color: var(--gray-light);">Billing Cycle:</span>
                            <span><%= order.billingCycle %></span>
                        </div>
                        <div style="display: flex; justify-content: between;">
                            <span style="color: var(--gray-light);">Created:</span>
                            <span><%= moment(order.createdAt).format('MMM D, YYYY HH:mm') %></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Pricing -->
            <div>
                <h4 style="margin-bottom: 1rem; color: var(--light);">Pricing</h4>
                <div style="background: var(--dark); padding: 1.5rem; border-radius: 8px;">
                    <div style="display: grid; gap: 0.75rem;">
                        <div style="display: flex; justify-content: between;">
                            <span style="color: var(--gray-light);">Original Price:</span>
                            <span>₹<%= originalPrice %></span>
                        </div>
                        <div style="display: flex; justify-content: between;">
                            <span style="color: var(--gray-light);">Discount:</span>
                            <span style="color: var(--success);">-₹<%= order.discount || 0 %></span>
                        </div>
                        <div style="display: flex; justify-content: between; border-top: 1px solid var(--border); padding-top: 0.75rem;">
                            <span style="color: var(--light); font-weight: 600;">Total Paid:</span>
                            <span style="font-weight: 600;">₹<%= order.price %></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Product & User Info -->
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem; margin-top: 2rem;">
            
            <!-- Product Information -->
            <div>
                <h4 style="margin-bottom: 1rem; color: var(--light);">Product</h4>
                <div style="background: var(--dark); padding: 1.5rem; border-radius: 8px;">
                    <% if (product) { %>
                        <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem;">
                            <% if (product.image) { %>
                            <img src="<%= product.image %>" alt="<%= product.name %>" class="img-thumbnail"
                                 onerror="this.src='/images/default-product.png'">
                            <% } %>
                            <div>
                                <div style="font-weight: 600;"><%= product.name %></div>
                                <div style="color: var(--gray-light); font-size: 0.875rem;"><%= product.category %></div>
                            </div>
                        </div>
                        <a href="/admin/products/<%= product.id %>/edit" class="btn btn-outline btn-sm">
                            View Product
                        </a>
                    <% } else { %>
                        <div style="color: var(--gray-light);">Product not found</div>
                    <% } %>
                </div>
            </div>

            <!-- User Information -->
            <div>
                <h4 style="margin-bottom: 1rem; color: var(--light);">Customer</h4>
                <div style="background: var(--dark); padding: 1.5rem; border-radius: 8px;">
                    <% if (user) { %>
                        <div style="margin-bottom: 1rem;">
                            <div style="font-weight: 600;"><%= user.firstName %> <%= user.lastName %></div>
                            <div style="color: var(--gray-light); font-size: 0.875rem;"><%= user.email %></div>
                            <% if (user.phone) { %>
                            <div style="color: var(--gray-light); font-size: 0.875rem;"><%= user.phone %></div>
                            <% } %>
                        </div>
                        <a href="/admin/users/<%= user.id %>" class="btn btn-outline btn-sm">
                            View User
                        </a>
                    <% } else { %>
                        <div style="color: var(--gray-light);">User not found</div>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- Delete Order -->
        <% if (order.status !== 'active') { %>
        <div style="margin-top: 2rem; padding-top: 2rem; border-top: 1px solid var(--border);">
            <form action="/admin/orders/<%= order.id %>/delete" method="POST" 
                  onsubmit="return confirmDelete('Are you sure you want to delete this order? This action cannot be undone.')">
                <button type="submit" class="btn btn-danger">
                    <i class="fas fa-trash"></i> Delete Order
                </button>
            </form>
        </div>
        <% } %>
    </div>
</div>

<%- include('../partials/admin-footer') %>