<%- include('../partials/header') %>

<div class="fade-in-up max-w-4xl mx-auto">
    <!-- Page Header -->
    <div class="page-header mb-6">
        <h1 class="page-title">Security Settings</h1>
        <p class="page-subtitle">Manage your password and security preferences</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
        
        <!-- Sidebar Navigation -->
        <aside class="category-card h-fit">
            <h3 class="text-xl font-semibold mb-4">Account Settings</h3>

            <nav class="space-y-1">

                <a href="/profile"
                   class="block p-2 rounded transition hover:bg-primary-light/10 hover:text-primary <%= activePage === 'profile' ? 'bg-primary/10 text-primary font-medium' : 'text-text-secondary' %>">
                    <i class="fas fa-user mr-2"></i> Personal Information
                </a>

                <a href="/profile/security"
                   class="block p-2 rounded transition <%= activePage === 'security' ? 'bg-primary/10 text-primary font-medium' : 'text-text-secondary hover:text-primary hover:bg-primary-light/10' %>">
                    <i class="fas fa-shield-alt mr-2"></i> Security
                </a>

                <a href="/orders"
                   class="block p-2 rounded transition hover:bg-primary-light/10 hover:text-primary text-text-secondary">
                    <i class="fas fa-shopping-bag mr-2"></i> Order History
                </a>

                <a href="/tickets"
                   class="block p-2 rounded transition hover:bg-primary-light/10 hover:text-primary text-text-secondary">
                    <i class="fas fa-headset mr-2"></i> Support Tickets
                </a>
            </nav>
        </aside>

        <!-- Change Password Form -->
        <section class="category-card lg:col-span-2">
            <h3 class="text-xl font-semibold mb-4">Change Password</h3>

            <form action="/profile/security" method="POST" class="space-y-4">

                <div class="form-group">
                    <label class="form-label">Current Password *</label>
                    <input type="password" name="currentPassword" class="form-input" placeholder="Enter your current password" required>
                </div>

                <div class="form-group">
                    <label class="form-label">New Password *</label>
                    <input type="password" name="newPassword" class="form-input" placeholder="Enter new password" required>
                    <small class="text-sm text-text-muted block mt-1">Minimum 8 characters</small>
                </div>

                <div class="form-group">
                    <label class="form-label">Confirm New Password *</label>
                    <input type="password" name="confirmPassword" class="form-input" placeholder="Confirm new password" required>
                </div>

                <button type="submit" class="btn btn-primary w-full sm:w-auto">
                    <i class="fas fa-key mr-1"></i> Update Password
                </button>
            </form>
        </section>
    </div>

    <!-- Security Tips -->
    <section class="category-card mt-4">
        <h3 class="text-xl font-semibold mb-4">
            <i class="fas fa-shield-alt text-primary mr-1"></i> Security Tips
        </h3>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            
            <div class="space-y-3">
                <div class="flex gap-3">
                    <i class="fas fa-check text-success mt-1"></i>
                    <div>
                        <strong>Use a strong password</strong>
                        <p class="text-sm text-text-muted">
                            Include letters, numbers, and special characters.
                        </p>
                    </div>
                </div>

                <div class="flex gap-3">
                    <i class="fas fa-check text-success mt-1"></i>
                    <div>
                        <strong>Don't reuse passwords</strong>
                        <p class="text-sm text-text-muted">Use unique passwords for different services.</p>
                    </div>
                </div>
            </div>

            <div class="space-y-3">
                <div class="flex gap-3">
                    <i class="fas fa-check text-success mt-1"></i>
                    <div>
                        <strong>Enable 2FA if available</strong>
                        <p class="text-sm text-text-muted">Add an extra layer of security to your account.</p>
                    </div>
                </div>

                <div class="flex gap-3">
                    <i class="fas fa-check text-success mt-1"></i>
                    <div>
                        <strong>Monitor account activity</strong>
                        <p class="text-sm text-text-muted">Regularly check your login history.</p>
                    </div>
                </div>
            </div>

        </div>
    </section>

    <!-- Active Sessions -->
    <section class="category-card mt-4">
        <h3 class="text-xl font-semibold mb-4">Active Sessions</h3>

        <div class="space-y-3">
            <div class="flex items-center justify-between p-3 rounded-md bg-bg-secondary">
                <div>
                    <p class="font-medium">Current Session</p>
                    <p class="text-sm text-text-muted">
                        Started <%= moment().fromNow() %> • <%= user.lastIp || 'IP not available' %>
                    </p>
                </div>

                <span class="text-xs px-3 py-1 rounded-full bg-success text-white">Active</span>
            </div>
        </div>

        <div class="mt-4 text-center">
            <a href="/logout" class="btn btn-outline btn-sm">
                <i class="fas fa-sign-out-alt mr-1"></i> Logout All Sessions
            </a>
        </div>
    </section>
</div>

<%- include('../partials/footer') %>
