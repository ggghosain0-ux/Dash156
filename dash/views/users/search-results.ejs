<%- include('../partials/header') %>

<div class="card">
    <div class="card-header">
        <h1 class="card-title">
            <i class="fas fa-search"></i> Search Results
            <% if (searchQuery) { %>
                for "<%= searchQuery %>"
            <% } %>
        </h1>
        
        <form action="/search" method="GET" style="display: flex; gap: 0.5rem;">
            <input type="text" name="q" class="form-input" placeholder="Search products..." value="<%= searchQuery || '' %>" style="width: 300px;">
            <button type="submit" class="btn btn-primary">
                <i class="fas fa-search"></i> Search
            </button>
        </form>
    </div>

    <!-- Search Filters -->
    <div style="padding: 1.5rem; border-bottom: 1px solid var(--border-color);">
        <div class="grid" style="grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem;">
            <div>
                <label class="form-label">Category</label>
                <select class="form-select" onchange="updateCategoryFilter(this.value)">
                    <option value="">All Categories</option>
                    <% categories.forEach(cat => { %>
                        <option value="<%= cat.slug %>" <%= currentCategory === cat.slug ? 'selected' : '' %>>
                            <%= cat.name %> (<%= cat.count %>)
                        </option>
                    <% }); %>
                </select>
            </div>
            
            <div>
                <label class="form-label">Sort By</label>
                <select class="form-select" onchange="updateSortFilter(this.value)">
                    <option value="relevance" <%= sortBy === 'relevance' ? 'selected' : '' %>>Relevance</option>
                    <option value="price_low" <%= sortBy === 'price_low' ? 'selected' : '' %>>Price: Low to High</option>
                    <option value="price_high" <%= sortBy === 'price_high' ? 'selected' : '' %>>Price: High to Low</option>
                    <option value="name" <%= sortBy === 'name' ? 'selected' : '' %>>Name A-Z</option>
                    <option value="newest" <%= sortBy === 'newest' ? 'selected' : '' %>>Newest First</option>
                </select>
            </div>
            
            <div>
                <label class="form-label">Price Range</label>
                <select class="form-select" onchange="updatePriceFilter(this.value)">
                    <option value="">Any Price</option>
                    <option value="0-500" <%= priceRange === '0-500' ? 'selected' : '' %>>Under ₹500</option>
                    <option value="500-1000" <%= priceRange === '500-1000' ? 'selected' : '' %>>₹500 - ₹1000</option>
                    <option value="1000-2000" <%= priceRange === '1000-2000' ? 'selected' : '' %>>₹1000 - ₹2000</option>
                    <option value="2000+" <%= priceRange === '2000+' ? 'selected' : '' %>>Over ₹2000</option>
                </select>
            </div>
        </div>
    </div>

    <!-- Results Summary -->
    <div style="padding: 1rem 1.5rem; background: var(--bg-tertiary); border-bottom: 1px solid var(--border-color);">
        <div style="display: flex; justify-content: between; align-items: center;">
            <span class="text-secondary">
                Found <strong><%= totalResults %></strong> products
                <% if (searchQuery) { %> for "<%= searchQuery %>"<% } %>
                <% if (currentCategory) { %> in <%= categories.find(c => c.slug === currentCategory)?.name %><% } %>
            </span>
            
            <% if (searchQuery || currentCategory || sortBy !== 'relevance') { %>
                <a href="/products" class="btn btn-outline btn-sm">
                    <i class="fas fa-times"></i> Clear Filters
                </a>
            <% } %>
        </div>
    </div>

    <% if (products && products.length > 0) { %>
        <div class="product-grid" style="padding: 1.5rem;">
            <% products.forEach(product => { %>
                <div class="product-card">
                    <% if (product.image) { %>
                        <img src="<%= product.image %>" alt="<%= product.name %>" class="product-image">
                    <% } else { %>
                        <div class="product-image" style="display: flex; align-items: center; justify-content: center;">
                            <i class="fas fa-server" style="font-size: 3rem; color: var(--text-muted);"></i>
                        </div>
                    <% } %>
                    <div class="product-content">
                        <h3 class="product-title"><%= product.name %></h3>
                        <p class="product-description"><%= product.description.substring(0, 100) %>...</p>
                        
                        <div class="mb-2">
                            <span class="badge badge-info"><%= product.category %></span>
                        </div>
                        
                        <!-- Highlight search terms in specs -->
                        <% if (product.specs) { %>
                            <div style="margin-bottom: 1rem;">
                                <% Object.entries(product.specs).slice(0, 2).forEach(([key, value]) => { %>
                                    <div style="font-size: 0.875rem; color: var(--text-secondary); margin-bottom: 0.25rem;">
                                        <strong><%= key.toUpperCase() %>:</strong> <%= value %>
                                    </div>
                                <% }); %>
                            </div>
                        <% } %>
                        
                        <div class="product-price mb-2">
                            ₹<%= product.priceMonthly %>/mo
                        </div>
                        
                        <div style="display: flex; gap: 0.5rem;">
                            <a href="/products/<%= product.id %>" class="btn btn-primary" style="flex: 1;">
                                View Details
                            </a>
                        </div>
                    </div>
                </div>
            <% }); %>
        </div>

        <!-- Pagination -->
        <% if (pagination && pagination.totalPages > 1) { %>
            <div class="text-center mt-3">
                <div style="display: inline-flex; gap: 0.5rem; align-items: center;">
                    <% if (pagination.page > 1) { %>
                        <a href="?q=<%= searchQuery %>&page=<%= pagination.page - 1 %><%= currentCategory ? '&category=' + currentCategory : '' %><%= sortBy !== 'relevance' ? '&sort=' + sortBy : '' %><%= priceRange ? '&price=' + priceRange : '' %>" 
                           class="btn btn-outline btn-sm">
                            <i class="fas fa-chevron-left"></i> Previous
                        </a>
                    <% } %>
                    
                    <span class="text-secondary">
                        Page <%= pagination.page %> of <%= pagination.totalPages %>
                    </span>
                    
                    <% if (pagination.page < pagination.totalPages) { %>
                        <a href="?q=<%= searchQuery %>&page=<%= pagination.page + 1 %><%= currentCategory ? '&category=' + currentCategory : '' %><%= sortBy !== 'relevance' ? '&sort=' + sortBy : '' %><%= priceRange ? '&price=' + priceRange : '' %>" 
                           class="btn btn-outline btn-sm">
                            Next <i class="fas fa-chevron-right"></i>
                        </a>
                    <% } %>
                </div>
            </div>
        <% } %>
    <% } else { %>
        <div class="text-center p-4">
            <i class="fas fa-search" style="font-size: 3rem; color: var(--text-muted); margin-bottom: 1rem;"></i>
            <h3>No products found</h3>
            <p class="text-secondary mb-3">
                <% if (searchQuery) { %>
                    No products found for "<%= searchQuery %>"
                <% } else { %>
                    No products match your current filters
                <% } %>
            </p>
            <div style="display: flex; gap: 1rem; justify-content: center;">
                <a href="/products" class="btn btn-primary">Browse All Products</a>
                <a href="/" class="btn btn-outline">Back to Home</a>
            </div>
        </div>
    <% } %>
</div>

<!-- Search Tips -->
<div class="card mt-3">
    <h3 class="mb-2"><i class="fas fa-lightbulb"></i> Search Tips</h3>
    <div class="grid grid-3">
        <div>
            <strong>Use specific terms</strong>
            <p class="text-secondary" style="font-size: 0.875rem;">Try "Linux VPS" instead of "server"</p>
        </div>
        <div>
            <strong>Check spelling</strong>
            <p class="text-secondary" style="font-size: 0.875rem;">Double-check your search terms</p>
        </div>
        <div>
            <strong>Try categories</strong>
            <p class="text-secondary" style="font-size: 0.875rem;">Browse by category for better results</p>
        </div>
    </div>
</div>

<script>
function updateCategoryFilter(category) {
    const url = new URL(window.location);
    if (category) {
        url.searchParams.set('category', category);
    } else {
        url.searchParams.delete('category');
    }
    url.searchParams.delete('page'); // Reset to first page
    window.location.href = url.toString();
}

function updateSortFilter(sort) {
    const url = new URL(window.location);
    if (sort && sort !== 'relevance') {
        url.searchParams.set('sort', sort);
    } else {
        url.searchParams.delete('sort');
    }
    url.searchParams.delete('page'); // Reset to first page
    window.location.href = url.toString();
}

function updatePriceFilter(price) {
    const url = new URL(window.location);
    if (price) {
        url.searchParams.set('price', price);
    } else {
        url.searchParams.delete('price');
    }
    url.searchParams.delete('page'); // Reset to first page
    window.location.href = url.toString();
}

// Highlight search terms in product titles and descriptions
document.addEventListener('DOMContentLoaded', function() {
    const searchQuery = '<%= searchQuery %>';
    if (!searchQuery) return;
    
    const terms = searchQuery.toLowerCase().split(' ').filter(term => term.length > 2);
    if (terms.length === 0) return;
    
    const productTitles = document.querySelectorAll('.product-title');
    const productDescriptions = document.querySelectorAll('.product-description');
    
    function highlightText(element, terms) {
        let html = element.innerHTML;
        terms.forEach(term => {
            const regex = new RegExp(`(${term})`, 'gi');
            html = html.replace(regex, '<mark style="background: rgba(59, 130, 246, 0.3); padding: 0.1rem 0.2rem; border-radius: 0.2rem;">$1</mark>');
        });
        element.innerHTML = html;
    }
    
    productTitles.forEach(title => highlightText(title, terms));
    productDescriptions.forEach(desc => highlightText(desc, terms));
});
</script>

<%- include('../partials/footer') %>