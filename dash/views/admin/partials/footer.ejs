</main>

<!-- Footer -->
<footer class="mt-auto py-3 border-top bg-light">
    <div class="container-fluid">
        <div class="row align-items-center">
            <div class="col-md-4">
                <p class="mb-0 text-muted small">
                    <i class="fas fa-shield-alt me-1 text-primary"></i>
                    &copy; 2024 <%= settings.site_name || 'HostingService' %> Admin Panel. 
                    <span class="d-none d-md-inline">All rights reserved.</span>
                </p>
            </div>
            <div class="col-md-4 text-center">
                <div class="d-flex align-items-center justify-content-center">
                    <span class="badge bg-success me-2" id="systemStatus">
                        <i class="fas fa-circle me-1"></i>System Online
                    </span>
                    <small class="text-muted" id="loadTime">
                        Loaded in <span id="loadTimeValue">0</span>ms
                    </small>
                </div>
            </div>
            <div class="col-md-4 text-md-end">
                <div class="d-flex flex-column flex-md-row justify-content-md-end align-items-center">
                    <small class="text-muted me-md-3 mb-1 mb-md-0">
                        <i class="fas fa-user me-1 text-info"></i>
                        <strong><%= user.firstName %> <%= user.lastName %></strong>
                        <% if (user.isAdmin) { %>
                            <span class="badge bg-primary ms-1">Admin</span>
                        <% } %>
                    </small>
                    <small class="text-muted">
                        <i class="fas fa-clock me-1 text-warning"></i>
                        <span id="serverTime"><%= new Date().toLocaleString() %></span>
                    </small>
                </div>
            </div>
        </div>
        
        <!-- Quick Stats Row -->
        <div class="row mt-2 pt-2 border-top">
            <div class="col-12">
                <div class="d-flex flex-wrap justify-content-center gap-3">
                    <small class="text-muted">
                        <i class="fas fa-microchip me-1"></i>
                        Memory: <span id="memoryUsage">--</span>
                    </small>
                    <small class="text-muted">
                        <i class="fas fa-database me-1"></i>
                        DB: <span id="dbStatus" class="text-success">Connected</span>
                    </small>
                    <small class="text-muted">
                        <i class="fas fa-hdd me-1"></i>
                        Storage: <span id="storageUsage">--</span>
                    </small>
                    <small class="text-muted">
                        <i class="fas fa-users me-1"></i>
                        Active: <span id="activeUsers">--</span>
                    </small>
                </div>
            </div>
        </div>
    </div>
</footer>
</div>
</div>
</div>

<!-- Quick Action Buttons -->
<div class="position-fixed bottom-0 end-0 p-3" style="z-index: 11">
<div class="btn-group-vertical shadow">
<button class="btn btn-primary btn-sm rounded-circle mb-2" data-bs-toggle="tooltip" data-bs-placement="left" title="Quick Actions" id="quickActionsBtn">
<i class="fas fa-bolt"></i>
</button>
<button class="btn btn-success btn-sm rounded-circle mb-2 d-none quick-action" data-bs-toggle="tooltip" data-bs-placement="left" title="New Order" onclick="window.location.href='/admin/orders/new'">
<i class="fas fa-plus"></i>
</button>
<button class="btn btn-info btn-sm rounded-circle mb-2 d-none quick-action" data-bs-toggle="tooltip" data-bs-placement="left" title="New Ticket" onclick="window.location.href='/admin/tickets'">
<i class="fas fa-ticket-alt"></i>
</button>
<button class="btn btn-warning btn-sm rounded-circle mb-2 d-none quick-action" data-bs-toggle="tooltip" data-bs-placement="left" title="Refresh Data" onclick="location.reload()">
<i class="fas fa-sync-alt"></i>
</button>
<button class="btn btn-secondary btn-sm rounded-circle quick-action" data-bs-toggle="tooltip" data-bs-placement="left" title="Back to Top" onclick="scrollToTop()">
<i class="fas fa-arrow-up"></i>
</button>
</div>
</div>

<!-- Scripts -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.datatables.net/1.11.5/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.11.5/js/dataTables.bootstrap5.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/chart.js/3.7.0/chart.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.29.1/moment.min.js"></script>

<script>
// Performance tracking
const pageLoadTime = Date.now() - performance.timing.navigationStart;
$('#loadTimeValue').text(pageLoadTime);

// Auto-dismiss alerts with improved timing
setTimeout(() => {
$('.alert').alert('close');
}, 6000);

// Update server time with moment.js
function updateServerTime() {
const now = moment();
$('#serverTime').text(now.format('YYYY-MM-DD HH:mm:ss'));

// Update relative time every minute
if (now.second() === 0) {
updateSystemStats();
}
}
setInterval(updateServerTime, 1000);

// Initialize DataTables with enhanced options
$(document).ready(function() {
$('.data-table').DataTable({
pageLength: 25,
responsive: true,
dom: '<"row"<"col-sm-12 col-md-6"l><"col-sm-12 col-md-6"f>>rt<"row"<"col-sm-12 col-md-5"i><"col-sm-12 col-md-7"p>>',
language: {
search: "_INPUT_",
searchPlaceholder: "Search...",
lengthMenu: "_MENU_ records per page"
}
});

// Initialize tooltips
var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
return new bootstrap.Tooltip(tooltipTriggerEl);
});

// Load system stats
updateSystemStats();

// Load notification counts
loadNotificationCounts();
});

// Mobile sidebar toggle
$('#sidebarToggle').on('click', function() {
$('#adminSidebar').toggleClass('collapsed');
$('.col-md-10').toggleClass('col-md-12');
});

// System statistics
async function updateSystemStats() {
try {
// Simulate system stats - in real app, this would be API calls
const memoryUsage = (Math.random() * 80 + 10).toFixed(1);
const storageUsage = (Math.random() * 70 + 15).toFixed(1);
const activeUsers = Math.floor(Math.random() * 50 + 10);

$('#memoryUsage').text(memoryUsage + '%');
$('#storageUsage').text(storageUsage + '%');
$('#activeUsers').text(activeUsers);

// Update memory usage color
$('#memoryUsage').removeClass('text-success text-warning text-danger');
if (memoryUsage > 80) $('#memoryUsage').addClass('text-danger');
else if (memoryUsage > 60) $('#memoryUsage').addClass('text-warning');
else $('#memoryUsage').addClass('text-success');

} catch (error) {
console.error('Error updating system stats:', error);
}
}

// Load notification counts
async function loadNotificationCounts() {
try {
// Simulate API calls for notification counts
const pendingOrders = Math.floor(Math.random() * 5);
const unreadTickets = Math.floor(Math.random() * 8);
const newUsers = Math.floor(Math.random() * 3);

// Update badges
if (pendingOrders > 0) {
$('#pendingOrdersBadge').text(pendingOrders).removeClass('d-none');
$('#pendingOrdersNotification').html(`
    <i class="fas fa-shopping-cart me-2 text-warning"></i>
    ${pendingOrders} pending orders
`);
}

if (unreadTickets > 0) {
$('#unreadTicketsBadge').text(unreadTickets).removeClass('d-none');
$('#unreadTicketsNotification').html(`
    <i class="fas fa-ticket-alt me-2 text-danger"></i>
    ${unreadTickets} unread tickets
`);
}

if (newUsers > 0) {
$('#newUsersBadge').text(newUsers).removeClass('d-none');
}

// Update notification count
const totalNotifications = pendingOrders + unreadTickets;
$('#notificationCount').text(totalNotifications);

} catch (error) {
console.error('Error loading notifications:', error);
}
}

// Quick actions toggle
$('#quickActionsBtn').on('click', function() {
$('.quick-action').toggleClass('d-none');
});

// Scroll to top function
function scrollToTop() {
window.scrollTo({ top: 0, behavior: 'smooth' });
}

// Keyboard shortcuts
$(document).on('keydown', function(e) {
// Ctrl + K for search focus
if (e.ctrlKey && e.key === 'k') {
e.preventDefault();
$('.dataTables_filter input').focus();
}

// Escape to close modals
if (e.key === 'Escape') {
$('.modal').modal('hide');
}
});

// Auto-refresh data every 5 minutes
setInterval(() => {
if (document.visibilityState === 'visible') {
loadNotificationCounts();
updateSystemStats();
}
}, 300000);

// Page visibility handling
document.addEventListener('visibilitychange', function() {
if (!document.hidden) {
loadNotificationCounts();
updateSystemStats();
}
});

// Error handling for DataTables
$.fn.DataTable.ext.errMode = 'throw';

// Performance monitoring
window.addEventListener('load', function() {
const loadTime = Date.now() - performance.timing.navigationStart;
console.log('Page fully loaded in', loadTime, 'ms');

if (loadTime > 3000) {
$('#systemStatus')
.removeClass('bg-success')
.addClass('bg-warning')
.html('<i class="fas fa-exclamation-triangle me-1"></i>Performance Warning');
}
});
</script>
</body>
</html>