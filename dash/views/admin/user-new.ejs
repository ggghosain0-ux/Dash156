<%- include('../partials/admin-header') %>

<div class="card fade-in">
    <div class="card-header">
        <h3 class="card-title">Create New User</h3>
        <a href="/admin/users" class="btn btn-outline">Back to Users</a>
    </div>
    <div style="padding: 1.5rem;">
        <form action="/admin/users" method="POST">
            
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem;">
                <div class="form-group">
                    <label class="form-label">First Name</label>
                    <input type="text" name="firstName" value="<%= user.firstName || '' %>" class="form-control" required>
                </div>
                
                <div class="form-group">
                    <label class="form-label">Last Name</label>
                    <input type="text" name="lastName" value="<%= user.lastName || '' %>" class="form-control" required>
                </div>
            </div>
            
            <div class="form-group">
                <label class="form-label">Email</label>
                <input type="email" name="email" value="<%= user.email || '' %>" class="form-control" required>
            </div>
            
            <div class="form-group">
                <label class="form-label">Phone</label>
                <input type="tel" name="phone" value="<%= user.phone || '' %>" class="form-control">
            </div>
            
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem;">
                <div class="form-group">
                    <label>
                        <input type="checkbox" name="isAdmin" <%= user.isAdmin ? 'checked' : '' %>> Administrator
                    </label>
                </div>
                
                <div class="form-group">
                    <label>
                        <input type="checkbox" name="isActive" checked> Active User
                    </label>
                </div>
            </div>
            
            <button type="submit" class="btn btn-primary">Create User</button>
        </form>
    </div>
</div>

<%- include('../partials/admin-footer') %>