<%- include('../partials/admin-header') %>

<div class="card fade-in">
    <div class="card-header">
        <h3 class="card-title">General Settings</h3>
    </div>
    <div style="padding: 1.5rem;">
        <form action="/admin/settings/general" method="POST" enctype="multipart/form-data">
            <div class="form-group">
                <label class="form-label">Site Name</label>
                <input type="text" name="site_name" value="<%= settings.site_name || '' %>" class="form-control" required>
            </div>
            
            <div class="form-group">
                <label class="form-label">Site Description</label>
                <textarea name="site_description" class="form-control" rows="3"><%= settings.site_description || '' %></textarea>
            </div>
            
            <div class="form-group">
                <label class="form-label">Contact Email</label>
                <input type="email" name="contact_email" value="<%= settings.contact_email || '' %>" class="form-control" required>
            </div>
            
            <div class="form-group">
                <label class="form-label">Discord Server Link</label>
                <input type="url" name="discord_server" value="<%= settings.discord_server || '' %>" class="form-control" placeholder="https://discord.gg/yourinvite">
            </div>
            
            <div class="form-group">
                <label class="form-label">Site Logo</label>
                <input type="file" name="site_logo" accept="image/*" class="form-control" 
                       onchange="previewImage(this, 'logoPreview')">
                <% if (settings.site_logo) { %>
                <div style="margin-top: 1rem;">
                    <img src="/<%= settings.site_logo %>" id="logoPreview" class="img-preview">
                </div>
                <% } else { %>
                <div style="margin-top: 1rem;">
                    <img src="" id="logoPreview" class="img-preview" style="display: none;">
                </div>
                <% } %>
            </div>
            
            <button type="submit" class="btn btn-primary">Save General Settings</button>
        </form>
    </div>
</div>

<div class="card fade-in">
    <div class="card-header">
        <h3 class="card-title">Maintenance Mode</h3>
    </div>
    <div style="padding: 1.5rem;">
        <form action="/admin/settings/maintenance" method="POST">
            <div class="form-group">
                <label class="form-label">Maintenance Mode</label>
                <select name="maintenance_mode" class="form-control">
                    <option value="off" <%= settings.maintenance_mode === 'off' ? 'selected' : '' %>>Off</option>
                    <option value="on" <%= settings.maintenance_mode === 'on' ? 'selected' : '' %>>On</option>
                </select>
            </div>
            <button type="submit" class="btn btn-primary">Save Maintenance Settings</button>
        </form>
    </div>
</div>

<div class="card fade-in">
    <div class="card-header">
        <h3 class="card-title">Payment Settings (Razorpay)</h3>
    </div>
    <div style="padding: 1.5rem;">
        <form action="/admin/settings/razorpay" method="POST">
            <div class="form-group">
                <label class="form-label">Razorpay Key ID</label>
                <input type="text" name="razorpay_key_id" value="<%= settings.razorpay_key_id || '' %>" class="form-control">
            </div>
            
            <div class="form-group">
                <label class="form-label">Razorpay Key Secret</label>
                <input type="password" name="razorpay_key_secret" value="<%= settings.razorpay_key_secret || '' %>" class="form-control">
            </div>
            
            <button type="submit" class="btn btn-primary">Save Payment Settings</button>
        </form>
    </div>
</div>

<%- include('../partials/admin-footer') %>