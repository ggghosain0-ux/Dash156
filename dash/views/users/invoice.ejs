<%- include('../partials/header') %>

<div class="fade-in-up" style="max-width: 800px; margin: 0 auto;">
    <div class="page-header">
        <h1 class="page-title">Invoice</h1>
        <p class="page-subtitle">Order #<%= order.id %></p>
    </div>

    <div class="category-card">
        <!-- Invoice Header -->
        <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-3 mb-6 pb-3 border-b border-border">
            <div>
                <h2 style="font-size: 1.5rem; font-weight: 700; color: var(--primary-light);">
                    INVOICE
                </h2>
                <p class="text-text-secondary">#<%= order.id %></p>
            </div>
            
            <div class="text-right">
                <div class="text-lg font-semibold"><%= siteName %></div>
                <div class="text-text-secondary text-sm">Invoice Date: <%= moment(order.paymentTime || order.createdAt).format('MMM D, YYYY') %></div>
            </div>
        </div>

        <!-- Bill From / To -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
            <div>
                <h3 style="font-size: 1.125rem; font-weight: 600; margin-bottom: 1rem;">Bill From</h3>
                <div class="text-text-secondary">
                    <div><strong><%= siteName %></strong></div>
                    <div>support@<%= siteName.toLowerCase().replace(' ', '') %>.com</div>
                    <div>+1 (555) 123-4567</div>
                </div>
            </div>
            
            <div>
                <h3 style="font-size: 1.125rem; font-weight: 600; margin-bottom: 1rem;">Bill To</h3>
                <div class="text-text-secondary">
                    <div><strong><%= user.firstName %> <%= user.lastName %></strong></div>
                    <div><%= user.email %></div>
                    <% if (user.phone) { %>
                        <div><%= user.phone %></div>
                    <% } %>
                    <% if (user.address) { %>
                        <div><%= user.address %></div>
                        <% if (user.city || user.state || user.postalCode) { %>
                            <div>
                                <%= user.city %><%= user.city && user.state ? ', ' : '' %>
                                <%= user.state %><%= (user.city || user.state) && user.postalCode ? ' ' : '' %>
                                <%= user.postalCode %>
                            </div>
                        <% } %>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- Order Details -->
        <div class="mb-6">
            <h3 style="font-size: 1.125rem; font-weight: 600; margin-bottom: 1rem;">Order Details</h3>
            
            <div class="p-3 rounded" style="background: var(--bg-tertiary);">
                <table style="width: 100%; border-collapse: collapse;">
                    <thead>
                        <tr style="border-bottom: 1px solid var(--border);">
                            <th style="text-align: left; padding: 0.5rem 0;">Description</th>
                            <th style="text-align: right; padding: 0.5rem 0;">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td style="padding: 1rem 0;">
                                <div><strong><%= order.productName %></strong></div>
                                <div class="text-text-muted text-sm">
                                    <%= order.productCategory %> • 
                                    <%= order.billingCycle.charAt(0).toUpperCase() + order.billingCycle.slice(1) %> billing
                                </div>
                            </td>
                            <td style="text-align: right; padding: 1rem 0;">₹<%= originalPrice %></td>
                        </tr>
                        
                        <% if (order.discount > 0) { %>
                            <tr>
                                <td style="padding: 0.5rem 0;">
                                    <div class="text-text-muted">Discount</div>
                                </td>
                                <td style="text-align: right; padding: 0.5rem 0; color: var(--success);">
                                    -₹<%= order.discount %>
                                </td>
                            </tr>
                        <% } %>
                        
                        <tr style="border-top: 1px solid var(--border);">
                            <td style="padding: 1rem 0;">
                                <strong>Total</strong>
                            </td>
                            <td style="text-align: right; padding: 1rem 0;">
                                <strong style="font-size: 1.25rem; color: var(--primary-light);">
                                    ₹<%= order.price %>
                                </strong>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Payment Information -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
            <div>
                <h3 style="font-size: 1.125rem; font-weight: 600; margin-bottom: 1rem;">Payment Information</h3>
                
                <div class="space-y-2 text-sm">
                    <div class="flex justify-between">
                        <span class="text-text-muted">Payment Method:</span>
                        <span class="capitalize"><%= order.paymentMethod %></span>
                    </div>
                    <% if (order.razorpayPaymentId) { %>
                        <div class="flex justify-between">
                            <span class="text-text-muted">Payment ID:</span>
                            <span><%= order.razorpayPaymentId %></span>
                        </div>
                    <% } %>
                    <% if (order.paymentTime) { %>
                        <div class="flex justify-between">
                            <span class="text-text-muted">Payment Date:</span>
                            <span><%= moment(order.paymentTime).format('MMM D, YYYY [at] h:mm A') %></span>
                        </div>
                    <% } %>
                    <div class="flex justify-between">
                        <span class="text-text-muted">Status:</span>
                        <span class="text-success">Paid</span>
                    </div>
                </div>
            </div>
            
            <div>
                <h3 style="font-size: 1.125rem; font-weight: 600; margin-bottom: 1rem;">Service Information</h3>
                
                <div class="space-y-2 text-sm">
                    <div class="flex justify-between">
                        <span class="text-text-muted">Order Date:</span>
                        <span><%= moment(order.createdAt).format('MMM D, YYYY') %></span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-text-muted">Billing Cycle:</span>
                        <span class="capitalize"><%= order.billingCycle %></span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-text-muted">Next Billing:</span>
                        <span>
                            <%= moment(order.paymentTime || order.createdAt).add(
                                order.billingCycle === 'monthly' ? 1 : 
                                order.billingCycle === 'quarterly' ? 3 : 12, 
                                'months'
                            ).format('MMM D, YYYY') %>
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Notes -->
        <div class="p-3 rounded text-center" style="background: var(--bg-tertiary);">
            <p class="text-text-muted text-sm">
                Thank you for your business! This is a computer-generated invoice and does not require a physical signature.
            </p>
        </div>

        <!-- Actions -->
        <div class="flex justify-center gap-2 mt-6 pt-6 border-t border-border">
            <% if (print) { %>
                <button onclick="window.print()" class="btn btn-primary">
                    <i class="fas fa-print"></i> Print Invoice
                </button>
            <% } %>
            <a href="/orders/<%= order.id %>" class="btn btn-outline">
                <i class="fas fa-arrow-left"></i> Back to Order
            </a>
        </div>
    </div>
</div>

<style>
    @media print {
        .header, .footer, .btn {
            display: none !important;
        }
        
        body {
            background: white !important;
            color: black !important;
        }
        
        .category-card {
            border: 1px solid #ddd !important;
            box-shadow: none !important;
        }
    }
</style>

<%- include('../partials/footer') %>