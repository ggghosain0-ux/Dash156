<%- include('../partials/header') %>

<div class="fade-in-up">
    <!-- Breadcrumb -->
    <nav class="mb-3" style="color: var(--text-secondary);">
        <a href="/dashboard" class="text-text-secondary">Dashboard</a>
        <span class="mx-2">/</span>
        <a href="/orders" class="text-text-secondary">Orders</a>
        <span class="mx-2">/</span>
        <span class="text-text-primary">Order #<%= order.id %></span>
    </nav>

    <div class="category-card">
        <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-3 mb-3">
            <div>
                <h1 class="page-title" style="font-size: 2rem; text-align: left; background: none; -webkit-text-fill-color: var(--text-primary);">
                    <%= order.productName %>
                </h1>
                <p class="text-text-secondary">Order #<%= order.id %> • Placed on <%= moment(order.createdAt).format('MMMM D, YYYY') %></p>
            </div>

            <div class="flex gap-2">
                <% if (order.status === 'active') { %>
                    <a href="/orders/<%= order.id %>/invoice" class="btn btn-primary">
                        <i class="fas fa-file-invoice"></i> Download Invoice
                    </a>
                <% } %>
                
                <% if (canRetry) { %>
                    <form action="/retry-payment/<%= order.id %>" method="POST">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-credit-card"></i> Retry Payment
                        </button>
                    </form>
                <% } %>
            </div>
        </div>

        <!-- Order Status -->
        <div class="p-3 rounded mb-3" style="background: var(--bg-tertiary);">
            <div class="flex items-center justify-between">
                <div>
                    <strong>Order Status:</strong>
                    <span class="text-xs px-2 py-1 rounded-full ml-2" style="
                        background: <%= 
                            order.status === 'active' ? 'var(--success)' : 
                            order.status === 'pending' ? 'var(--warning)' : 
                            order.status === 'cancelled' ? 'var(--danger)' : 
                            order.status === 'paid' ? 'var(--info)' : 'var(--secondary)'
                        %>20; 
                        color: <%= 
                            order.status === 'active' ? 'var(--success)' : 
                            order.status === 'pending' ? 'var(--warning)' : 
                            order.status === 'cancelled' ? 'var(--danger)' : 
                            order.status === 'paid' ? 'var(--info)' : 'var(--secondary)'
                        %>;
                    ">
                        <%= order.status.charAt(0).toUpperCase() + order.status.slice(1) %>
                    </span>
                </div>
                
                <% if (order.paymentTime) { %>
                    <div class="text-text-secondary text-sm">
                        Paid on <%= moment(order.paymentTime).format('MMM D, YYYY [at] h:mm A') %>
                    </div>
                <% } %>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-3">
            <!-- Order Details -->
            <div>
                <h3 style="font-size: 1.25rem; font-weight: 600; margin-bottom: 1rem;">Order Details</h3>
                
                <div class="space-y-2">
                    <div class="flex justify-between">
                        <span class="text-text-muted">Product:</span>
                        <span><%= order.productName %></span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-text-muted">Category:</span>
                        <span><%= order.productCategory %></span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-text-muted">Billing Cycle:</span>
                        <span class="capitalize"><%= order.billingCycle %></span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-text-muted">Payment Method:</span>
                        <span class="capitalize"><%= order.paymentMethod %></span>
                    </div>
                    <% if (order.razorpayPaymentId) { %>
                        <div class="flex justify-between">
                            <span class="text-text-muted">Payment ID:</span>
                            <span class="text-sm"><%= order.razorpayPaymentId %></span>
                        </div>
                    <% } %>
                </div>
            </div>

            <!-- Pricing -->
            <div>
                <h3 style="font-size: 1.25rem; font-weight: 600; margin-bottom: 1rem;">Pricing Details</h3>
                
                <div class="space-y-2">
                    <div class="flex justify-between">
                        <span class="text-text-muted">Original Price:</span>
                        <span>₹<%= originalPrice %></span>
                    </div>
                    
                    <% if (order.discount > 0) { %>
                        <div class="flex justify-between">
                            <span class="text-text-muted">Discount:</span>
                            <span class="text-success">-₹<%= order.discount %></span>
                        </div>
                    <% } %>
                    
                    <div class="flex justify-between pt-2 border-t border-border">
                        <strong class="text-text-primary">Total Paid:</strong>
                        <strong class="text-primary-light">₹<%= order.price %></strong>
                    </div>
                </div>
            </div>
        </div>

        <!-- Product Information -->
        <% if (product) { %>
            <div class="mt-3 p-3 rounded" style="background: var(--bg-tertiary);">
                <h3 style="font-size: 1.25rem; font-weight: 600; margin-bottom: 1rem;">Product Information</h3>
                
                <div class="grid grid-cols-2 lg:grid-cols-4 gap-2">
                    <div class="text-center">
                        <i class="fas fa-microchip text-primary-light mb-1"></i>
                        <div class="text-sm text-text-muted">CPU</div>
                        <div class="font-semibold"><%= product.specs.cpu %></div>
                    </div>
                    <div class="text-center">
                        <i class="fas fa-memory text-primary-light mb-1"></i>
                        <div class="text-sm text-text-muted">RAM</div>
                        <div class="font-semibold"><%= product.specs.ram %></div>
                    </div>
                    <div class="text-center">
                        <i class="fas fa-hdd text-primary-light mb-1"></i>
                        <div class="text-sm text-text-muted">Storage</div>
                        <div class="font-semibold"><%= product.specs.disk %></div>
                    </div>
                    <div class="text-center">
                        <i class="fas fa-network-wired text-primary-light mb-1"></i>
                        <div class="text-sm text-text-muted">Bandwidth</div>
                        <div class="font-semibold"><%= product.specs.bandwidth %></div>
                    </div>
                </div>
            </div>
        <% } %>

        <!-- Support Section -->
        <div class="mt-3 text-center">
            <p class="text-text-secondary mb-2">Need help with your order?</p>
            <a href="/tickets/new" class="btn btn-outline">
                <i class="fas fa-headset"></i> Contact Support
            </a>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>