<%- include('../partials/admin-header') %>

<div class="card fade-in">
    <div class="card-header">
        <h3 class="card-title"><%= title %></h3>
        <a href="/admin/categories" class="btn btn-outline">Back to Categories</a>
    </div>
    <div style="padding: 1.5rem;">
        <form action="<%= category.id ? '/admin/categories/' + category.id : '/admin/categories' %>" 
              method="POST" enctype="multipart/form-data">
            
            <div class="form-group">
                <label class="form-label">Category Name</label>
                <input type="text" name="name" value="<%= category.name || '' %>" class="form-control" required>
            </div>
            
            <div class="form-group">
                <label class="form-label">Description</label>
                <textarea name="description" class="form-control" rows="3"><%= category.description || '' %></textarea>
            </div>
            
            <div class="form-group">
                <label class="form-label">Category Image</label>
                <input type="file" name="image" accept="image/*" class="form-control" 
                       onchange="previewImage(this, 'imagePreview')">
                
                <% if (category.image) { %>
                <div style="margin-top: 1rem;">
                    <img src="<%= category.image %>" id="imagePreview" class="img-preview">
                    <div style="margin-top: 0.5rem;">
                        <label>
                            <input type="checkbox" name="removeImage"> Remove current image
                        </label>
                    </div>
                </div>
                <% } else { %>
                <div style="margin-top: 1rem;">
                    <img src="" id="imagePreview" class="img-preview" style="display: none;">
                </div>
                <% } %>
            </div>
            
            <div class="form-group">
                <label>
                    <input type="checkbox" name="isActive" <%= category.isActive ? 'checked' : '' %>> Active Category
                </label>
            </div>
            
            <button type="submit" class="btn btn-primary">
                <%= category.id ? 'Update Category' : 'Create Category' %>
            </button>
        </form>
    </div>
</div>

<%- include('../partials/admin-footer') %>