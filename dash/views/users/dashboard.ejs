<%- include('../partials/header') %>

<div class="fade-in-up">
    <div class="page-header">
        <h1 class="page-title">Dashboard</h1>
        <p class="page-subtitle">Welcome back, <%= user.firstName %>! Here's your hosting overview.</p>
    </div>

    <!-- Stats Overview -->
    <div class="categories-grid mb-3">
        <div class="category-card text-center">
            <i class="fas fa-shopping-bag" style="font-size: 2.5rem; color: var(--primary); margin-bottom: 1rem;"></i>
            <h3 class="category-title"><%= stats.totalOrders || 0 %></h3>
            <p class="category-description">Total Orders</p>
        </div>

        <div class="category-card text-center">
            <i class="fas fa-headset" style="font-size: 2.5rem; color: var(--info); margin-bottom: 1rem;"></i>
            <h3 class="category-title"><%= stats.openTickets || 0 %></h3>
            <p class="category-description">Open Tickets</p>
        </div>

        <div class="category-card text-center">
            <i class="fas fa-wallet" style="font-size: 2.5rem; color: var(--success); margin-bottom: 1rem;"></i>
            <h3 class="category-title">₹<%= totalSpent || 0 %></h3>
            <p class="category-description">Total Spent</p>
        </div>

        <div class="category-card text-center">
            <i class="fas fa-server" style="font-size: 2.5rem; color: var(--warning); margin-bottom: 1rem;"></i>
            <h3 class="category-title"><%= orders.filter(o => o.status === 'active').length %></h3>
            <p class="category-description">Active Services</p>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-3">
        <!-- Recent Orders -->
        <section class="category-card">
            <div class="flex justify-between items-center mb-3">
                <h2 style="font-size: 1.5rem; font-weight: 700;">Recent Orders</h2>
                <a href="/orders" class="btn btn-outline btn-sm">
                    View All <i class="fas fa-arrow-right"></i>
                </a>
            </div>

            <% if (orders && orders.length > 0) { %>
                <div class="space-y-2">
                    <% orders.forEach(order => { %>
                        <div class="flex justify-between items-center p-2 rounded" style="background: var(--bg-tertiary);">
                            <div>
                                <div class="font-semibold"><%= order.productName %></div>
                                <div class="text-sm text-text-muted">
                                    #<%= order.id %> • <%= moment(order.createdAt).format('MMM D, YYYY') %>
                                </div>
                            </div>
                            <div class="text-right">
                                <div class="font-semibold">₹<%= order.price %></div>
                                <span class="text-xs px-2 py-1 rounded-full" style="
                                    background: <%= 
                                        order.status === 'active' ? 'var(--success)' : 
                                        order.status === 'pending' ? 'var(--warning)' : 
                                        order.status === 'cancelled' ? 'var(--danger)' : 'var(--secondary)'
                                    %>20; 
                                    color: <%= 
                                        order.status === 'active' ? 'var(--success)' : 
                                        order.status === 'pending' ? 'var(--warning)' : 
                                        order.status === 'cancelled' ? 'var(--danger)' : 'var(--secondary)'
                                    %>;
                                ">
                                    <%= order.status.charAt(0).toUpperCase() + order.status.slice(1) %>
                                </span>
                            </div>
                        </div>
                    <% }); %>
                </div>
            <% } else { %>
                <div class="text-center p-3">
                    <i class="fas fa-shopping-bag" style="font-size: 3rem; color: var(--text-muted); margin-bottom: 1rem;"></i>
                    <p class="text-text-secondary">No orders yet</p>
                    <a href="/products" class="btn btn-primary mt-2">
                        <i class="fas fa-rocket"></i> Browse Products
                    </a>
                </div>
            <% } %>
        </section>

        <!-- Recent Activity -->
        <section class="category-card">
            <h2 style="font-size: 1.5rem; font-weight: 700; margin-bottom: 1rem;">Recent Activity</h2>

            <% if (recentActivity && recentActivity.length > 0) { %>
                <div class="space-y-2">
                    <% recentActivity.forEach(activity => { %>
                        <div class="flex items-center gap-3 p-2 rounded" style="background: var(--bg-tertiary);">
                            <div class="flex items-center justify-center w-8 h-8 rounded-full" 
                                 style="background: var(--primary); color: white;">
                                <i class="fas fa-<%= activity.type === 'order' ? 'shopping-bag' : 'ticket-alt' %>"></i>
                            </div>
                            <div class="flex-1">
                                <div class="font-semibold"><%= activity.desc %></div>
                                <div class="text-sm text-text-muted">
                                    <%= moment(activity.createdAt).fromNow() %>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                </div>
            <% } else { %>
                <div class="text-center p-3">
                    <i class="fas fa-history" style="font-size: 3rem; color: var(--text-muted); margin-bottom: 1rem;"></i>
                    <p class="text-text-secondary">No recent activity</p>
                </div>
            <% } %>
        </section>

        <!-- Liked Products -->
        <% if (likedProducts && likedProducts.length > 0) { %>
            <section class="category-card">
                <div class="flex justify-between items-center mb-3">
                    <h2 style="font-size: 1.5rem; font-weight: 700;">Liked Products</h2>
                    <a href="/products" class="btn btn-outline btn-sm">
                        Browse More <i class="fas fa-arrow-right"></i>
                    </a>
                </div>

                <div class="space-y-2">
                    <% likedProducts.forEach(product => { %>
                        <div class="flex items-center gap-3 p-2 rounded" style="background: var(--bg-tertiary);">
                            <img src="<%= product.image %>" alt="<%= product.name %>" 
                                 class="w-12 h-12 rounded object-cover"
                                 onerror="this.src='/images/default-product.png'">
                            <div class="flex-1">
                                <div class="font-semibold"><%= product.name %></div>
                                <div class="text-sm text-text-muted">₹<%= product.priceMonthly %>/mo</div>
                            </div>
                            <a href="/products/<%= product.id %>" class="btn btn-outline btn-sm">
                                View
                            </a>
                        </div>
                    <% }); %>
                </div>
            </section>
        <% } %>

        <!-- Quick Actions -->
        <section class="category-card">
            <h2 style="font-size: 1.5rem; font-weight: 700; margin-bottom: 1rem;">Quick Actions</h2>
            <div class="grid grid-cols-2 gap-2">
                <a href="/products" class="btn btn-outline text-center">
                    <i class="fas fa-server"></i> Order Service
                </a>
                <a href="/tickets/new" class="btn btn-outline text-center">
                    <i class="fas fa-plus"></i> New Ticket
                </a>
                <a href="/profile" class="btn btn-outline text-center">
                    <i class="fas fa-user"></i> Profile
                </a>
                <a href="/orders" class="btn btn-outline text-center">
                    <i class="fas fa-list"></i> My Orders
                </a>
            </div>
        </section>
    </div>
</div>

<%- include('../partials/footer') %>